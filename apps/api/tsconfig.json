{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@sohaara/database": ["../../packages/database/src"],
      "@sohaara/database/*": ["../../packages/database/src/*"],
      "@sohaara/auth": ["../../packages/auth/src"],
      "@sohaara/auth/*": ["../../packages/auth/src/*"],
      "@sohaara/shared": ["../../packages/shared/src"],
      "@sohaara/shared/*": ["../../packages/shared/src/*"],
      "@sohaara/types": ["../../packages/types/src"],
      "@sohaara/types/*": ["../../packages/types/src/*"],
      "@sohaara/notifications": ["../../packages/notifications/src"],
      "@sohaara/notifications/*": ["../../packages/notifications/src/*"],
      "@sohaara/storage": ["../../packages/storage/src"],
      "@sohaara/storage/*": ["../../packages/storage/src/*"],
      "@sohaara/search": ["../../packages/search/src"],
      "@sohaara/search/*": ["../../packages/search/src/*"],
      "@sohaara/analytics": ["../../packages/analytics/src"],
      "@sohaara/analytics/*": ["../../packages/analytics/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
