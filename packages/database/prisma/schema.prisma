// ─── App Log (server-side telemetry) ───

model AppLog {
  id          String   @id @default(uuid()) @db.Uuid
  level       String   @db.VarChar(20)     // info, warn, error, debug, verbose, fatal
  context     String?  @db.VarChar(100)    // controller/service/module name

  // HTTP request
  method      String?  @db.VarChar(10)
  path        String?  @db.VarChar(1000)
  queryString String?  @db.Text             // raw query string
  statusCode  Int?

  // Timing
  duration    Int?                           // response time in ms

  // Error
  errorCode   String?  @db.VarChar(50)      // 400, 404, 500, P2002, EACCES, etc.
  errorName   String?  @db.VarChar(100)     // NotFoundException, SyntaxError, etc.
  message     String   @db.Text
  stack       String?  @db.Text             // full stack trace

  // Request/response payloads for debugging
  requestHeaders  Json     @default("{}")
  requestBody     Json     @default("{}")
  responseBody    Json     @default("{}")    // truncated to 10KB
  responseHeaders Json     @default("{}")

  // Metadata (anything else: query params, db query info, env flags)
  metadata    Json     @default("{}")

  // Origin
  userId      String?  @db.Uuid
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text

  // Environment context
  nodeVersion String?  @db.VarChar(20)
  environment String?  @db.VarChar(20)      // development, production, test
  hostname    String?  @db.VarChar(255)

  timestamp   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([level])
  @@index([context])
  @@index([method])
  @@index([path])
  @@index([statusCode])
  @@index([errorCode])
  @@index([timestamp])
  @@index([userId])
  @@index([duration])
  @@map("app_logs")
}

