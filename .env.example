# ─── App ───
NODE_ENV=development
APP_NAME=Sohaara LMS
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
ADMIN_URL=http://localhost:3001

# ─── Database ───
DATABASE_URL=postgresql://sohaara:sohaara@localhost:5432/sohaara_lms?schema=public

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Meilisearch ───
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=sohaara-master-key

# ─── MinIO ───
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=sohaara
MINIO_SECRET_KEY=sohaara-secret-key
MINIO_BUCKET=sohaara-lms
MINIO_USE_SSL=false

# ─── Auth ───
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=sohaara-lms

# ─── Encryption ───
ENCRYPTION_KEY=your-32-char-encryption-key-change-in-prod

# ─── AI Provider ───
AI_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Storage ───
STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# ─── Auth Provider ───
AUTH_PROVIDER=local
